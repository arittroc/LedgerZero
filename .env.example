# Database Credentials
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=ledgerzero

# Connection string for local development (pointing to localhost)
# DATABASE_URL="postgresql://user:password@localhost:5432/ledgerzero"

# Connection string for Docker environment (pointing to the 'db' service)
DATABASE_URL="postgresql://user:password@db:5432/ledgerzero"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Razorpay Configuration
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="..."

# AI Configuration
GEMINI_API_KEY="AIzaSy..."
